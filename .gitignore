## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://gist.github.com/visualstudio/ms-dotnettools-gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Dynamic Link Libraries
*.dll
*.exe
*.pdb
*.swp
*.thumbs.db
*.tmp

# SQLite databases
*.db
*.db-shm
*.db-wal

# macOS
.DS_Store

# App settings secrets
appsettings.Development.json
