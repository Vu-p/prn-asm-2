@page
@model app.Pages.Auth.AccessDeniedModel
@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">
            <div class="card border-0 shadow">
                <div class="card-body text-center p-5">
                    <div class="mb-4 text-danger">
                        <i class="bi bi-x-octagon-fill" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="mb-3">Truy cập bị từ chối</h2>
                    <p class="text-muted mb-4">Bạn không có quyền truy cập vào trang này. Vui lòng liên hệ quản trị viên nếu cần hỗ trợ.</p>
                    <div class="d-flex justify-content-center gap-2">
                        <a asp-page="/Index" class="btn btn-primary">
                            <i class="bi bi-house-door me-1"></i>Trang chủ
                        </a>
                        <a asp-page="/Auth/Login" class="btn btn-outline-secondary">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
