@page
@model app.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-3">Register</h2>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.AccountName" class="form-label">Full Name</label>
                <input asp-for="Input.AccountName" class="form-control" />
                <span asp-validation-for="Input.AccountName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.AccountEmail" class="form-label">Email</label>
                <input asp-for="Input.AccountEmail" class="form-control" />
                <span asp-validation-for="Input.AccountEmail" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.AccountPassword" class="form-label">Password</label>
                <input asp-for="Input.AccountPassword" class="form-control" type="password" />
                <span asp-validation-for="Input.AccountPassword" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.AccountRole" class="form-label">Role</label>
                <select asp-for="Input.AccountRole" class="form-select">
                    <option value="1">Staff</option>
                    <option value="2">Lecturer</option>
                </select>
                <span asp-validation-for="Input.AccountRole" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Register</button>
            <div class="mt-3">
                Already have an account? <a asp-page="/Auth/Login">Login here</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
