@page
@model app.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
    var firebaseApiKey = ViewData["FirebaseApiKey"]?.ToString() ?? "";
    var firebaseAuthDomain = ViewData["FirebaseAuthDomain"]?.ToString() ?? "";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-3">Login</h2>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>

        <div class="my-3 text-center text-muted">— or —</div>

        @Html.AntiForgeryToken()

        <div id="googleError" class="alert alert-danger d-none"></div>
        <button id="googleSignInBtn" class="btn btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            Sign in with Google
        </button>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <!-- Firebase SDK Compat -->
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>

    <script>
        const firebaseConfig = {
            apiKey: "@Html.Raw(Model.FirebaseApiKey)",
            authDomain: "@Html.Raw(Model.FirebaseAuthDomain)"
        };

        // Initialize Firebase
        if (!firebase.apps.length) {
            firebase.initializeApp(firebaseConfig);
        }
        const auth = firebase.auth();
        const provider = new firebase.auth.GoogleAuthProvider();

        const btnGoogleLogin = document.getElementById('googleSignInBtn');
        const errDiv = document.getElementById('googleError');
        const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');

        function showError(msg) {
            errDiv.textContent = msg;
            errDiv.classList.remove('d-none');
            errDiv.classList.add('alert-danger');
            errDiv.classList.remove('alert-success');
        }

        function showSuccess(msg) {
            errDiv.textContent = msg;
            errDiv.classList.remove('d-none');
            errDiv.classList.remove('alert-danger');
            errDiv.classList.add('alert-success');
        }

        btnGoogleLogin.addEventListener('click', async () => {
            btnGoogleLogin.disabled = true;
            btnGoogleLogin.textContent = 'Signing in...';
            errDiv.classList.add('d-none');
            
            try {
                const result = await auth.signInWithPopup(provider);
                const user = result.user;
                const idToken = await user.getIdToken();
                
                const csrfToken = tokenElement ? tokenElement.value : '';

                const resp = await fetch('?handler=ProcessGoogleLogin', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': csrfToken
                    },
                    body: JSON.stringify({ 
                        idToken: idToken, 
                        email: user.email, 
                        displayName: user.displayName || user.email 
                    })
                });

                const data = await resp.json();

                if (data.success) {
                    showSuccess(data.message);
                    setTimeout(() => {
                        window.location.href = data.redirect || '/';
                    }, 500);
                } else {
                    showError(data.message);
                    await auth.signOut();
                    resetButton();
                }
            } catch (e) {
                console.error('Google sign-in error:', e);
                showError(e.message || 'Google sign-in failed. Please try again.');
                resetButton();
            }
        });

        function resetButton() {
            btnGoogleLogin.disabled = false;
            btnGoogleLogin.innerHTML = `<svg class="me-2" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg> Sign in with Google`;
        }
    </script>
}
