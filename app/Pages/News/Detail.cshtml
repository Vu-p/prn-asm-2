@page "{id}"
@model app.Pages.News.DetailModel
@{
    ViewData["Title"] = Model.Article?.NewsTitle ?? "Article";
    var article = Model.Article!;
}

<div class="container my-5">
<div class="row g-4">
    <div class="col-lg-8">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/News/Public">News</a></li>
                @foreach (var h in Model.CategoryHierarchy)
                {
                    if (h.CategoryId == article.CategoryId)
                    {
                        <li class="breadcrumb-item active">@h.CategoryName</li>
                    }
                    else
                    {
                        <li class="breadcrumb-item"><a href="/News/Public?categoryId=@h.CategoryId">@h.CategoryName</a></li>
                    }
                }
            </ol>
        </nav>

        <article>
            <header class="mb-4">
                <div class="mb-3">
                    <span class="badge rounded-pill bg-primary-subtle text-dark border">@(article.Category?.CategoryName ?? "Uncategorized")</span>
                </div>
                <h1 class="display-5 fw-bold">@article.NewsTitle</h1>
                <p class="lead text-muted">@article.Headline</p>
                <div class="d-flex gap-3 text-muted small mb-3">
                    <span><i class="bi bi-person"></i> @(article.CreatedBy?.AccountName ?? "Unknown")</span>
                    <span><i class="bi bi-calendar3"></i> @article.CreatedDate.ToString("MMMM dd, yyyy")</span>
                    @if (article.ModifiedDate.HasValue)
                    {
                        <span><i class="bi bi-pencil"></i> Updated @article.ModifiedDate.Value.ToString("MMM dd, yyyy")</span>
                    }
                </div>

                @if (article.NewsTags.Any())
                {
                    <div class="mb-3">
                        @foreach (var newsTag in article.NewsTags.Where(nt => nt.Tag != null))
                        {
                            <span class="badge bg-primary me-1">#@newsTag.Tag!.TagName</span>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(article.ThumbnailUrl))
                {
                    <img src="@article.ThumbnailUrl" alt="@article.NewsTitle" class="img-fluid rounded shadow mb-4 w-100" style="max-height:420px; object-fit:cover;" />
                }
            </header>

            <div class="article-content">
                @Html.Raw(article.NewsContent)
            </div>

            @if (!string.IsNullOrWhiteSpace(article.NewsSource))
            {
                <footer class="mt-4 pt-3 border-top text-muted small">
                    <strong>Source:</strong> @article.NewsSource
                </footer>
            }
        </article>

        <div class="mt-5">
            <a href="/News/Public" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> Back to News
            </a>
        </div>
    </div>

    <aside class="col-lg-4">
        <div class="position-sticky" style="top: 20px;">
            <section class="card border-0 shadow-sm mb-4">
                <div class="card-header fw-semibold fs-4 related-header text-white">Related News</div>
                <div class="list-group list-group-flush related-list">
                    @if (Model.RelatedNews.Any())
                    {
                        @foreach (var related in Model.RelatedNews)
                        {
                            <a href="/News/Detail/@related.NewsArticleId" class="list-group-item list-group-item-action border-0 py-3">
                                <div class="fw-semibold lh-sm related-title">@related.NewsTitle</div>
                                <div class="small text-secondary mt-2">@related.CreatedDate.ToString("dd/MM/yyyy")</div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="list-group-item border-0 py-3 text-muted small">No related articles in this category yet.</div>
                    }
                </div>
            </section>

            <section class="card border-0 shadow-sm">
                <div class="card-header fw-semibold fs-4 category-header">Categories</div>
                <div class="list-group list-group-flush">
                    @foreach (var category in Model.AllCategories.Where(c => c.IsActive && c.ParentCategoryId == null))
                    {
                        <a href="/News/Public?categoryId=@category.CategoryId" class="list-group-item list-group-item-action border-0 py-3 @(Model.CategoryHierarchy.Any(h => h.CategoryId == category.CategoryId) ? "active" : "")">
                            <div class="fw-semibold">@category.CategoryName</div>
                            <small class="text-muted">News from @category.CategoryName</small>
                        </a>
                    }
                </div>
            </section>
        </div>
    </aside>
</div>
</div>

<style>
    .related-header {
        background-color: #2f3a5d;
    }

    .category-header {
        background-color: #dee5ef;
        color: #1f3556;
    }

    .related-list .list-group-item:not(:last-child) {
        border-bottom: 1px solid #eceff3 !important;
    }

    .related-list .list-group-item:hover .related-title {
        color: #0d47a1;
    }

    .related-title {
        color: #263a5a;
        transition: color 0.2s ease;
    }

    .list-group-item.active {
        background-color: #eef4ff;
        color: #0b4da2;
        border-left: 3px solid #0b61d8 !important;
    }

    .list-group-item.active .text-muted {
        color: #6d7f98 !important;
    }

    .article-content img { max-width: 100%; height: auto; border-radius: 8px; }
    .article-content p { line-height: 1.8; font-size: 1.05rem; }
    .article-content h2, .article-content h3 { margin-top: 1.5rem; }
    .article-content blockquote { border-left: 4px solid #0d6efd; padding-left: 1rem; color: #555; font-style: italic; }
</style>
