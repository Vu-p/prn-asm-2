@page
@model app.Pages.Admin.ReportModel
@{
    ViewData["Title"] = "Báo cáo thống kê";
}

<div class="container-fluid">
    <div class="card border-0 shadow-lg mb-4" style="background-color: var(--primary-color); border-radius: 1rem;">
        <div class="card-body p-4">
            <h2 class="fw-bold mb-2 text-white"><i class="bi bi-graph-up-arrow me-2"></i>Báo cáo và Thống kê</h2>
            <p class="mb-0" style="color: var(--secondary-color);">Tổng hợp bài viết theo khoảng thời gian</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Từ ngày</label>
                    <input type="date" name="startDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Đến ngày</label>
                    <input type="date" name="endDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted mb-1">Tổng bài viết</div>
                    <h3 class="fw-bold mb-0">@Model.ReportData.Count</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted mb-1">Đã duyệt</div>
                    <h3 class="fw-bold mb-0">@Model.ReportData.Count(x => x.NewsStatus == 1)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted mb-1">Chờ duyệt</div>
                    <h3 class="fw-bold mb-0">@Model.ReportData.Count(x => x.NewsStatus != 1)</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0">Danh sách bài viết (@Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy"))</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3">Ngày tạo</th>
                            <th class="py-3">Tiêu đề</th>
                            <th class="py-3">Chuyên mục</th>
                            <th class="py-3">Tác giả</th>
                            <th class="py-3">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var article in Model.ReportData)
                        {
                            <tr>
                                <td class="px-4">@article.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@article.NewsTitle</td>
                                <td>@article.Category?.CategoryName</td>
                                <td>@article.CreatedBy?.AccountName</td>
                                <td>
                                    @if (article.NewsStatus == 1)
                                    {
                                        <span class="badge bg-success">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-dark" style="background-color: var(--accent-color);">Chờ duyệt</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.ReportData.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">Không có dữ liệu trong khoảng thời gian đã chọn.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
