@page
@model app.Pages.Staff.ProfileModel
@{
    ViewData["Title"] = "Ho so ca nhan";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
            <div class="card border-0 shadow-lg">
                <div class="card-header border-0 p-4" style="background-color: var(--primary-color);">
                    <h3 class="card-title mb-0 text-white"><i class="bi bi-person-circle me-2"></i>Ho so ca nhan</h3>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <div class="alert alert-success">@Model.Message</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Profile.AccountName" class="form-label fw-semibold">Ho va ten</label>
                            <input asp-for="Profile.AccountName" class="form-control form-control-lg" />
                            <span asp-validation-for="Profile.AccountName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Profile.AccountEmail" class="form-label fw-semibold">Email</label>
                            <input asp-for="Profile.AccountEmail" class="form-control form-control-lg" readonly />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Profile.AccountPassword" class="form-label fw-semibold">Mat khau</label>
                            <input asp-for="Profile.AccountPassword" class="form-control form-control-lg" type="password" />
                            <span asp-validation-for="Profile.AccountPassword" class="text-danger small"></span>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-save me-1"></i>Cap nhat ho so
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
