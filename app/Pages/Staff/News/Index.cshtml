@page
@model app.Pages.Staff.News.IndexModel
@using System.Security.Claims
@{
    ViewData["Title"] = "News Article Management";
    var userId = short.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
    var isAdmin = User.IsInRole("Admin");
}

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>News Article Management</h2>
        <button type="button" class="btn btn-primary" onclick="openCreateModal()">Create New Article</button>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row row-cols-lg-auto g-3 align-items-center">
                <div class="col-12">
                    <input type="text" name="SearchTerm" class="form-control" placeholder="Search by title or headline..." value="@Model.SearchTerm">
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-secondary">Search</button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="newsTable">
                    <thead class="table-light">
                        <tr>
                            <th>Image</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Tags</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="newsTableBody">
                        @foreach (var article in Model.Articles)
                        {
                            bool canAction = isAdmin || (article.NewsStatus != 1 && article.CreatedById == userId);
                            <tr id="row-@article.NewsArticleId">
                                <td>
                                    @if (!string.IsNullOrEmpty(article.ThumbnailUrl))
                                    {
                                        <img src="@article.ThumbnailUrl" alt="thumb" style="width: 50px; height: 50px; object-fit: cover;" class="rounded shadow-sm" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:50px; height:50px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-bold">@article.NewsTitle</div>
                                    <small class="text-muted d-block">@article.Headline</small>
                                </td>
                                <td>@article.Category?.CategoryName</td>
                                <td>
                                    @foreach(var nt in article.NewsTags.Where(t => t.Tag != null))
                                    {
                                        <span class="badge bg-secondary me-1">#@nt.Tag!.TagName</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(article.NewsStatus == 1 ? "bg-success" : "bg-warning text-dark")">
                                        @(article.NewsStatus == 1 ? "Approved" : "Draft/Pending")
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" onclick="openEditModal('@article.NewsArticleId')" @(canAction ? "" : "disabled")>
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@article.NewsArticleId" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this article?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" @(canAction ? "" : "disabled")>
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- News Modal -->
<div class="modal fade" id="newsModal" tabindex="-1" aria-labelledby="newsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="newsForm" method="post" asp-page-handler="Upsert" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title" id="newsModalLabel">News Article</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="UpsertArticle.NewsArticleId" id="modalNewsId" />
                    <input type="hidden" asp-for="UpsertArticle.NewsContent" id="modalNewsContentHidden" />
                    
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="UpsertArticle.NewsTitle" class="form-label">Title</label>
                            <input asp-for="UpsertArticle.NewsTitle" class="form-control" id="modalNewsTitle" required />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="UpsertArticle.Headline" class="form-label">Headline</label>
                            <input asp-for="UpsertArticle.Headline" class="form-control" id="modalNewsHeadline" required />
                        </div>
                        
                        <div class="col-md-6 mb-3 text-center">
                             <label class="form-label d-block text-start">Thumbnail</label>
                             <div class="mb-2">
                                 <img id="thumbPreview" src="https://via.placeholder.com/150" alt="Preview" class="img-thumbnail" style="max-height: 150px;" />
                             </div>
                             <input type="file" asp-for="ThumbnailFile" class="form-control" id="modalThumbInput" accept="image/*" onchange="previewImage(this)" />
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="UpsertArticle.CategoryId" class="form-label">Category</label>
                                <select asp-for="UpsertArticle.CategoryId" class="form-select" id="modalNewsCategory" asp-items="@(new SelectList(Model.Categories, "CategoryId", "CategoryName"))" required>
                                    <option value="">-- Select Category --</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label asp-for="UpsertArticle.NewsStatus" class="form-label">Status</label>
                                <select asp-for="UpsertArticle.NewsStatus" class="form-select" id="modalNewsStatus" required>
                                    <option value="0">Draft/Pending</option>
                                    @if (isAdmin)
                                    {
                                        <option value="1">Approved</option>
                                    }
                                </select>
                                <small class="text-muted">Staff cannot edit after approval.</small>
                            </div>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label asp-for="UpsertArticle.NewsSource" class="form-label">Source</label>
                            <input asp-for="UpsertArticle.NewsSource" class="form-control" id="modalNewsSource" />
                        </div>
                        
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Content</label>
                            <div id="editor" style="height: 300px;"></div>
                        </div>
                        
                        <div class="col-md-12 mb-3">
                            <label asp-for="TagsInput" class="form-label">Tags</label>
                            <input asp-for="TagsInput" class="form-control" id="modalTagsInput" placeholder="e.g., Technology, News" />
                            <small class="text-muted">Separate multiple tags with commas.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="saveButton">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        const currentUserId = @userId;
        const isAdmin = '@isAdmin'.toLowerCase() === 'true';

        // Initialize Quill
        const quill = new Quill('#editor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link', 'image', 'clean']
                ]
            }
        });

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/news")
            .build();

        function createRowHtml(article) {
            const statusClass = article.newsStatus === 1 ? 'bg-success' : 'bg-warning text-dark';
            const statusText = article.newsStatus === 1 ? 'Approved' : 'Draft/Pending';
            const canAction = isAdmin || (article.newsStatus !== 1 && article.createdById == currentUserId);
            
            const thumb = article.thumbnailUrl 
                ? `<img src="${article.thumbnailUrl}" alt="thumb" style="width: 50px; height: 50px; object-fit: cover;" class="rounded shadow-sm" />`
                : `<div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:50px; height:50px;"><i class="bi bi-image text-muted"></i></div>`;

            const tags = (article.tagsInput || '').split(',').filter(t => t.trim()).map(t => `<span class="badge bg-secondary me-1">#${t.trim()}</span>`).join('');

            return `
                <tr id="row-${article.newsArticleId}" class="new-row">
                    <td>${thumb}</td>
                    <td>
                        <div class="fw-bold">${article.newsTitle}</div>
                        <small class="text-muted d-block">${article.headline}</small>
                    </td>
                    <td>${article.categoryName || ''}</td>
                    <td>${tags}</td>
                    <td>
                        <span class="badge ${statusClass}">${statusText}</span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="openEditModal('${article.newsArticleId}')" ${canAction ? '' : 'disabled'}>
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <form method="post" action="/Staff/News?handler=Delete&id=${article.newsArticleId}" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this article?')">
                             <input name="__RequestVerificationToken" type="hidden" value="${document.querySelector('input[name="__RequestVerificationToken"]').value}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" ${canAction ? '' : 'disabled'}>
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>`;
        }

        connection.on("ArticleCreated", function (article) {
            const tbody = document.getElementById('newsTableBody');
            tbody.insertAdjacentHTML('afterbegin', createRowHtml(article));
        });

        connection.on("ArticleUpdated", function (article) {
            const row = document.getElementById(`row-${article.newsArticleId}`);
            if (row) {
                const newRow = createRowHtml(article);
                row.outerHTML = newRow;
                document.getElementById(`row-${article.newsArticleId}`).classList.add('new-row');
            }
        });

        connection.on("ArticleDeleted", function (id) {
            const row = document.getElementById(`row-${id}`);
            if (row) row.remove();
        });

        connection.start().catch(err => console.error(err.toString()));

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('thumbPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        async function openCreateModal() {
            document.getElementById('newsForm').reset();
            document.getElementById('modalNewsId').value = '';
            document.getElementById('modalTagsInput').value = '';
            document.getElementById('thumbPreview').src = 'https://via.placeholder.com/150';
            quill.setContents([]);
            document.getElementById('newsModalLabel').innerText = 'Create News Article';
            new bootstrap.Modal(document.getElementById('newsModal')).show();
        }

        async function openEditModal(id) {
            const response = await fetch(`/Staff/News?handler=ArticleDetails&id=${id}`);
            const data = await response.json();

            if (data) {
                document.getElementById('modalNewsId').value = data.newsArticleId;
                document.getElementById('modalNewsTitle').value = data.newsTitle;
                document.getElementById('modalNewsHeadline').value = data.headline;
                document.getElementById('modalNewsCategory').value = data.categoryId;
                document.getElementById('modalNewsStatus').value = data.newsStatus;
                document.getElementById('modalNewsSource').value = data.newsSource || '';
                document.getElementById('thumbPreview').src = data.thumbnailUrl || 'https://via.placeholder.com/150';
                
                quill.root.innerHTML = data.newsContent || '';

                document.getElementById('modalTagsInput').value = data.tagsInput || '';

                document.getElementById('newsModalLabel').innerText = 'Edit News Article';
                new bootstrap.Modal(document.getElementById('newsModal')).show();
            }
        }

        document.getElementById('newsForm').onsubmit = function() {
            document.getElementById('modalNewsContentHidden').value = quill.root.innerHTML;
        };
    </script>
    <style>
        .new-row { animation: highlight 2s ease; }
        @@keyframes highlight { from { background-color: #fff9c4; } to { background-color: transparent; } }
        .table img { transition: transform 0.2s; }
        .table img:hover { transform: scale(3); z-index: 1000; position: relative; }
        .badge { font-weight: 500; }
    </style>
}
