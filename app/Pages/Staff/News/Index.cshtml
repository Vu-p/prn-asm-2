@page
@model app.Pages.Staff.News.IndexModel
@{
    ViewData["Title"] = "News Article Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>News Article Management</h2>
        <button type="button" class="btn btn-primary" onclick="openCreateModal()">Create New Article</button>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row row-cols-lg-auto g-3 align-items-center">
                <div class="col-12">
                    <input type="text" name="SearchTerm" class="form-control" placeholder="Search by title or headline..." value="@Model.SearchTerm">
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-secondary">Search</button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="newsTable">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Headline</th>
                            <th>Category</th>
                            <th>Created By</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="newsTableBody">
                        @foreach (var article in Model.Articles)
                        {
                            <tr id="row-@article.NewsArticleId">
                                <td>@article.NewsTitle</td>
                                <td>@article.Headline</td>
                                <td>@article.Category?.CategoryName</td>
                                <td>@article.CreatedBy?.AccountName</td>
                                <td>
                                    <span class="badge @(article.NewsStatus == 1 ? "bg-success" : "bg-secondary")">
                                        @(article.NewsStatus == 1 ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" onclick="openEditModal('@article.NewsArticleId')">Edit</button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@article.NewsArticleId" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this article?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- News Modal -->
<div class="modal fade" id="newsModal" tabindex="-1" aria-labelledby="newsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="newsForm" method="post" asp-page-handler="Upsert">
                <div class="modal-header">
                    <h5 class="modal-title" id="newsModalLabel">News Article</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="UpsertArticle.NewsArticleId" id="modalNewsId" />
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="UpsertArticle.NewsTitle" class="form-label">Title</label>
                            <input asp-for="UpsertArticle.NewsTitle" class="form-control" id="modalNewsTitle" required />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="UpsertArticle.Headline" class="form-label">Headline</label>
                            <input asp-for="UpsertArticle.Headline" class="form-control" id="modalNewsHeadline" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpsertArticle.CategoryId" class="form-label">Category</label>
                            <select asp-for="UpsertArticle.CategoryId" class="form-select" id="modalNewsCategory" asp-items="@(new SelectList(Model.Categories, "CategoryId", "CategoryName"))" required>
                                <option value="">-- Select Category --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpsertArticle.NewsStatus" class="form-label">Status</label>
                            <select asp-for="UpsertArticle.NewsStatus" class="form-select" id="modalNewsStatus" required>
                                <option value="1">Active</option>
                                <option value="0">Inactive</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="UpsertArticle.NewsSource" class="form-label">Source</label>
                            <input asp-for="UpsertArticle.NewsSource" class="form-control" id="modalNewsSource" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="UpsertArticle.NewsContent" class="form-label">Content</label>
                            <textarea asp-for="UpsertArticle.NewsContent" class="form-control" id="modalNewsContent" rows="5" required></textarea>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="TagsInput" class="form-label">Tags</label>
                            <input asp-for="TagsInput" class="form-control" id="modalTagsInput" placeholder="e.g., Technology, News" />
                            <small class="text-muted">Separate multiple tags with commas.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="saveButton">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/news")
            .build();

        function createRowHtml(article) {
            const statusClass = article.newsStatus === 1 ? 'bg-success' : 'bg-secondary';
            const statusText = article.newsStatus === 1 ? 'Active' : 'Inactive';
            return `
                <tr id="row-${article.newsArticleId}" class="new-row">
                    <td>${article.newsTitle}</td>
                    <td>${article.headline}</td>
                    <td>${article.categoryName || ''}</td>
                    <td>${article.accountName || ''}</td>
                    <td>
                        <span class="badge ${statusClass}">${statusText}</span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="openEditModal('${article.newsArticleId}')">Edit</button>
                        <form method="post" action="/Staff/News?handler=Delete&id=${article.newsArticleId}" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this article?')">
                             <input name="__RequestVerificationToken" type="hidden" value="${document.querySelector('input[name="__RequestVerificationToken"]').value}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>`;
        }

        connection.on("ArticleCreated", function (article) {
            const tbody = document.getElementById('newsTableBody');
            tbody.insertAdjacentHTML('afterbegin', createRowHtml(article));
        });

        connection.on("ArticleUpdated", function (article) {
            const row = document.getElementById(`row-${article.newsArticleId}`);
            if (row) {
                const statusClass = article.newsStatus === 1 ? 'bg-success' : 'bg-secondary';
                const statusText = article.newsStatus === 1 ? 'Active' : 'Inactive';
                row.cells[0].innerText = article.newsTitle;
                row.cells[1].innerText = article.headline;
                row.cells[2].innerText = article.categoryName || '';
                row.cells[3].innerText = article.accountName || '';
                row.querySelector('.badge').className = `badge ${statusClass}`;
                row.querySelector('.badge').innerText = statusText;
            }
        });

        connection.on("ArticleDeleted", function (id) {
            const row = document.getElementById(`row-${id}`);
            if (row) row.remove();
        });

        connection.start().catch(err => console.error(err.toString()));

        async function openCreateModal() {
            document.getElementById('newsForm').reset();
            document.getElementById('modalNewsId').value = '';
            document.getElementById('modalTagsInput').value = '';
            document.getElementById('newsModalLabel').innerText = 'Create News Article';
            new bootstrap.Modal(document.getElementById('newsModal')).show();
        }

        async function openEditModal(id) {
            const response = await fetch(`/Staff/News?handler=ArticleDetails&id=${id}`);
            const data = await response.json();

            if (data) {
                document.getElementById('modalNewsId').value = data.newsArticleId;
                document.getElementById('modalNewsTitle').value = data.newsTitle;
                document.getElementById('modalNewsHeadline').value = data.headline;
                document.getElementById('modalNewsCategory').value = data.categoryId;
                document.getElementById('modalNewsStatus').value = data.newsStatus;
                document.getElementById('modalNewsSource').value = data.newsSource || '';
                document.getElementById('modalNewsContent').value = data.newsContent;

                // Set tags
                document.getElementById('modalTagsInput').value = data.tagsInput || '';

                document.getElementById('newsModalLabel').innerText = 'Edit News Article';
                new bootstrap.Modal(document.getElementById('newsModal')).show();
            }
        }
    </script>
    <style>
        .new-row { animation: highlight 1.5s ease; }
        @@keyframes highlight { from { background-color: #fff9c4; } to { background-color: transparent; } }
    </style>
}
