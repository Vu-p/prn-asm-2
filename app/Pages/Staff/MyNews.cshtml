@page
@model app.Pages.Staff.MyNewsModel
@{
    ViewData["Title"] = User.IsInRole("Admin") ? "Quản lý bài viết" : "Bài viết của tôi";
    var isAdminView = User.IsInRole("Admin");
}

<div class="container-fluid">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-lg mb-4" style="background-color: var(--primary-color); border-radius: 1rem;">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-lg-8 text-white">
                    <h2 class="fw-bold mb-2">
                        <i class="bi bi-file-text-fill me-2"></i>@(isAdminView ? "Quản lý bài viết" : "Bài viết của tôi")
                    </h2>
                    <p class="mb-0" style="color: var(--secondary-color);">@(isAdminView ? "Quản lý và cập nhật tất cả bài viết" : "Theo dõi lịch sử bài viết của bạn")</p>
                </div>
                <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                    <a asp-page="/Staff/News/Index" asp-route-create="1" class="btn btn-lg shadow" style="background-color: var(--accent-color); color: var(--primary-color); font-weight: 600;">
                        <i class="bi bi-plus-circle me-2"></i>Tạo bài viết mới
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <label class="form-label fw-semibold text-muted small mb-2">TÌM KIẾM BÀI VIẾT</label>
            <div class="input-group input-group-lg">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0" id="searchInput" placeholder="Nhập tiêu đề hoặc chuyên mục...">
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="newsTable">
                    <thead style="background-color: var(--primary-color); color: white;">
                        <tr>
                            <th class="px-4 py-3">Tiêu đề</th>
                            <th class="py-3">Headline</th>
                            <th class="py-3">Chuyên mục</th>
                            @if (isAdminView)
                            {
                                <th class="py-3">Tác giả</th>
                            }
                            <th class="py-3">Ngày tạo</th>
                            <th class="py-3">Trạng thái</th>
                            <th class="py-3 text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var article in Model.Articles)
                        {
                            <tr class="news-row">
                                <td><strong class="news-title">@article.NewsTitle</strong></td>
                                <td class="text-muted">@article.Headline</td>
                                <td class="news-category">@(article.Category?.CategoryName ?? "-")</td>
                                @if (isAdminView)
                                {
                                    <td>@(article.CreatedBy?.AccountName ?? "-")</td>
                                }
                                <td>@article.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (article.NewsStatus == 1)
                                    {
                                        <span class="badge bg-success">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-dark" style="background-color: var(--accent-color);">Chờ duyệt</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group" aria-label="Article actions">
                                        @if (isAdminView && article.NewsStatus != 1 && article.CreatedBy != null && article.CreatedBy.AccountRole != 0)
                                        {
                                            <form method="post" asp-page-handler="Approve" asp-route-id="@article.NewsArticleId" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-check2-circle"></i> Duyệt
                                                </button>
                                            </form>
                                        }
                                        <a asp-page="/Staff/News/Index" asp-route-editId="@article.NewsArticleId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@article.NewsArticleId" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa bài viết này?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Articles.Any())
                        {
                            <tr>
                                <td colspan="@(isAdminView ? 7 : 6)" class="text-center py-4 text-muted">Chưa có bài viết nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('input', function () {
            const term = this.value.toLowerCase();
            document.querySelectorAll('#newsTable .news-row').forEach(row => {
                const title = row.querySelector('.news-title')?.textContent.toLowerCase() || '';
                const category = row.querySelector('.news-category')?.textContent.toLowerCase() || '';
                row.style.display = (title.includes(term) || category.includes(term)) ? '' : 'none';
            });
        });
    </script>
}
