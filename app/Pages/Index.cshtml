@page
@model IndexModel
@{
    ViewData["Title"] = "Trang chủ";
    var userName = User.Identity?.Name ?? "Khách";
    var roleName = User.IsInRole("Admin") ? "Admin" : User.IsInRole("Staff") ? "Staff" : "Lecturer";
}

<section class="home-hero card border-0 shadow-sm mb-3">
    <div class="card-body p-4 p-lg-5">
        <div class="row align-items-center g-4">
            <div class="col-lg-8 text-white">
                <h1 class="fw-bold mb-2"><i class="bi bi-newspaper me-2"></i>Chào mừng đến FU News Management System</h1>
                <p class="mb-3 text-light opacity-75">Hệ thống quản lý tin tức của FPT University</p>
                <div class="d-flex flex-wrap gap-2 home-action-row">
                    <span class="home-pill home-pill-light">Xin chào, @userName</span>
                    <span class="home-pill home-pill-accent">@roleName</span>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-page="/Staff/News/Index" class="btn btn-home-accent home-action-btn">
                            <i class="bi bi-plus-circle me-1"></i>Tạo bài viết mới
                        </a>
                    }
                </div>
            </div>
            <div class="col-lg-4 text-lg-end text-center">
                <i class="bi bi-journal-richtext home-hero-icon"></i>
            </div>
        </div>
    </div>
</section>

<section class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Tổng bài viết</div>
                    <div class="stat-value">@Model.TotalArticles</div>
                </div>
                <div class="stat-icon"><i class="bi bi-file-earmark-text"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Tổng người dùng</div>
                    <div class="stat-value">@Model.TotalUsers</div>
                </div>
                <div class="stat-icon"><i class="bi bi-people"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Chuyên mục</div>
                    <div class="stat-value">@Model.TotalCategories</div>
                </div>
                <div class="stat-icon"><i class="bi bi-folder"></i></div>
            </div>
        </div>
    </div>
</section>

<section>
    <h2 class="section-title mb-3"><i class="bi bi-card-list me-2"></i>Tin tức mới nhất</h2>
    <div class="row g-3">
        @foreach (var article in Model.LatestNews)
        {
            <div class="col-md-6 col-xl-4">
                <article class="card news-card h-100 border-0 shadow-sm">
                    <div class="card-body pb-2">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge rounded-pill text-bg-dark">@(article.Category?.CategoryName ?? "Chuyên mục")</span>
                            <small class="text-muted"><i class="bi bi-calendar-event me-1"></i>@article.CreatedDate.ToString("dd/MM/yyyy")</small>
                        </div>
                        <h3 class="news-title">@article.NewsTitle</h3>
                        <p class="news-desc text-muted">@article.Headline</p>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center pt-0">
                        <small class="text-muted"><i class="bi bi-person-circle me-1"></i>@(article.CreatedBy?.AccountName ?? "Lecturer")</small>
                        <a asp-page="/News/Detail" asp-route-id="@article.NewsArticleId" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-1"></i>Xem
                        </a>
                    </div>
                </article>
            </div>
        }
    </div>
</section>

<style>
    .home-hero {
        background: linear-gradient(135deg, var(--primary-color) 0%, #4b557d 100%);
        border-radius: 0.85rem;
    }

    .home-hero-icon {
        font-size: 6rem;
        opacity: 0.2;
        color: #fff;
    }

    .btn-home-accent {
        background-color: var(--accent-color);
        color: #1f2b47;
        font-weight: 600;
        border: 1px solid rgba(15, 39, 66, 0.12);
    }

    .btn-home-accent:hover {
        background-color: #e8cc95;
        color: #1f2b47;
    }

    .stat-card {
        border-radius: 0.8rem;
    }

    .stat-label {
        color: #5f7086;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .stat-value {
        font-size: 2rem;
        line-height: 1;
        font-weight: 800;
        color: var(--primary-color);
        margin-top: 0.35rem;
    }

    .stat-icon {
        width: 3rem;
        height: 3rem;
        border-radius: 50%;
        background-color: var(--primary-color);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary-color);
    }

    .news-card {
        border-radius: 0.7rem;
    }

    .news-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: #1f2f4c;
        line-height: 1.35;
        display: -webkit-box;
    .home-action-row {
        align-items: center;
        gap: 0.6rem !important;
    }

    .home-pill,
    .home-action-btn {
        height: 3rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 1rem;
        line-height: 1;
        font-size: 1.05rem;
        font-weight: 700;
        border-radius: 0.4rem;
        margin: 0;
        text-decoration: none;
    }

    .home-pill-light {
        background-color: #fff;
        color: #122136;
    }

    .home-pill-accent {
        background-color: var(--accent-color);
        color: #1f2b47;
    }

    .home-action-btn {
        border: 1px solid rgba(15, 39, 66, 0.12);
    }

        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 0.5rem;
    }

    .news-desc {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 3.9rem;
    }
</style>
